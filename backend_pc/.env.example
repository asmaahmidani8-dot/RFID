# ════════════════════════════════════════════════════════
# MODÈLE de configuration pour le PC USINE (backend_pc)
# → Copie ce fichier en ".env" dans le DOSSIER PARENT, et remplis
#   les valeurs <...> avec celles du .env du Raspberry Pi (cat ~/.env).
#   Le vrai .env n'est JAMAIS versionné (protégé par .gitignore).
# ════════════════════════════════════════════════════════

# ── MySQL : LOCAL au PC ──
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=rfid_app
MYSQL_PASSWORD=rfid_pass
MYSQL_DB=rfid_buc

# ── Oracle DB (testé OK depuis le PC : port 1521) ──
ORACLE_HOST=qahceaexa-scan.ge-healthcare.net
ORACLE_PORT=1521
ORACLE_SERVICE=<copie depuis le .env du Pi>
ORACLE_USER=<copie depuis le .env du Pi>
ORACLE_PASSWORD=<copie depuis le .env du Pi>

# ── MSCA / MWA (testé OK depuis le PC : port 10200) ──
MSCA_HOST=ebsgltest.ge-healthcare.net
MSCA_PORT=10200
MSCA_USER=250028087
MSCA_PASSWORD=<copie depuis le .env du Pi>
MSCA_ORG=BXD
MSCA_DATABASE=GLTEST

# ── Divers ──
ORACLE_SYNC=true
FLASK_DEBUG=false
