# MSCA Daily Maintenance中かどうかのチェック True:実行可、False:実行不可
def isMscaTransaction(log):
    try:
        now = datetime.now()
        mscaStart = datetime.combine(now.date(), msca_maint_start)
        mscaEnd = datetime.combine(now.date(), msca_maint_end)        
        if (mscaStart <= now and mscaEnd >= now): #MSCA Daily Maintenance中は移倉実行禁止 Y.Innami 202309
            return False
        else:
            return True
        
    except Exception as e:
        log.sendLog("Transaction", "error", str(e))
        return False

# 禁止期間かどうかのチェック True:実行可、False:実行不可
def isExecTransaction(log):
    try:
        connection = pymysql.connect(host=DB_HOST,
                                    user=DB_USER,
                                    password=DB_PASSWORD,
                                    db=DB_SCHEMA,
                                    charset='utf8',
                                    cursorclass=pymysql.cursors.DictCursor)
        try:
            now = datetime.now()
            nowDateTime = now.strftime("%Y-%m-%d %H:%M:%S")
            periodFlags = {}

            # ORG_MASTER と禁止期間テーブルを JOIN し、1回のSQLで取得
            with connection.cursor() as cursor:
                sql = "SELECT \
                            org.ORG_ID as orgID, \
                            COUNT(period.ORG_ID) as periodCount \
                        FROM \
                            " + TABLE_ORG_MASTER + " org \
                            LEFT JOIN " + TABLE_PERIOD + " period \
                                ON org.ORG_ID = period.ORG_ID \
                                AND period.DateTime_From <= %s \
                                AND period.DateTime_To >= %s \
                        WHERE \
                            org.IS_ACTIVE = 1 \
                        GROUP BY \
                            org.ORG_ID \
                        ORDER BY \
                            org.ORG_ID;"
                cursor.execute(sql, (nowDateTime, nowDateTime))
                results = cursor.fetchall()

            for row in results:
                # periodCount > 0 の場合は禁止期間中
                periodFlags[row["orgID"]] = (row["periodCount"] == 0)
            
            return periodFlags
        finally:
            connection.close()
    except pymysql.err.OperationalError as e:
        log.sendLog("Transaction", "error", str(e) + ":DB接続エラー")
        return {}

